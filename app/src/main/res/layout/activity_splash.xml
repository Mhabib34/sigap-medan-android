<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8541A">

    <!-- Pattern background icon samar -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="top"
        android:src="@drawable/container"
        android:scaleType="centerCrop"
        android:alpha="0.15"
        app:tint="#FFFFFF" />

    <!-- Konten utama di tengah -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E8541A">

        <!-- Pattern background icon samar -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/container"
            android:scaleType="centerCrop"
            android:alpha="0.15"
            app:tint="#FFFFFF" />

        <!-- Logo di tengah (sudah include teks & tagline) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="200dp"
                android:layout_height="160dp"
                android:src="@drawable/logo"
                android:scaleType="fitCenter" />

            <!-- Subtitle (pindah ke sini) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="@font/poetsen_one_regular"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Sistem Informasi Gerakan Aksi Peduli Medan"
                android:textSize="16sp"
                android:textColor="#E4E4E4"
                android:textStyle="normal"/>
        </LinearLayout>

    </FrameLayout>

</FrameLayout>