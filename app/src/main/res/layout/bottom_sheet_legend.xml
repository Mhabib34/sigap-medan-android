<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_handle_bar"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LEGENDA PETA"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#888888"
        android:letterSpacing="0.1"
        android:layout_marginBottom="16dp"/>

    <!-- Merah: Kritis -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <View
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/bg_legend_red"
            android:layout_marginEnd="12dp"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvLabelKritis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kritis (≥6 laporan)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>
            <TextView
                android:id="@+id/tvSubKritis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perlu penanganan segera"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Kuning: Sedang -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <View
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/bg_legend_yellow"
            android:layout_marginEnd="12dp"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvLabelSedang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sedang (3–5 laporan)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>
            <TextView
                android:id="@+id/tvSubSedang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dalam proses penanganan"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Hijau: Rendah -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <View
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/bg_legend_green"
            android:layout_marginEnd="12dp"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvLabelRendah"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rendah (1–2 laporan)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>
            <TextView
                android:id="@+id/tvSubRendah"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Terpantau, tidak mendesak"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>