<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Avatar inisial -->
    <androidx.cardview.widget.CardView
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardCornerRadius="22dp"
        app:cardBackgroundColor="#E8541A"
        app:cardElevation="0dp">
        <TextView
            android:id="@+id/tvAvatarLeader"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="AW"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"/>
    </androidx.cardview.widget.CardView>

    <!-- Nama + Badge -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvNamaLeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Arya Wijaya"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"/>

        <TextView
            android:id="@+id/tvBadgeLeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="12 BADGES"
            android:textSize="10sp"
            android:textColor="#E8541A"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_kategori"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"/>

    </LinearLayout>

    <!-- Poin -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvPoinLeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8,420"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#E8541A"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PTS"
            android:textSize="10sp"
            android:textColor="#888888"/>

    </LinearLayout>

</LinearLayout>