<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg"
    android:fillViewport="true"
    android:fitsSystemWindows="true"> >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp"
        android:minHeight="100dp">

        <!-- Card utama -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- Icon lingkaran oranye -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/logo"
                    android:scaleType="centerInside" />

                <!-- Judul -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:fontFamily="@font/poetsen_one_regular"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <!-- Subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Gabung dan bangun Kota Medan\nbersama!"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"/>

                <!-- Spacer -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="20dp"/>

                <!-- Label NAMA LENGKAP -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NAMA LENGKAP"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <!-- Field Nama -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:cardCornerRadius="50dp"
                    app:cardBackgroundColor="#F2F2F2"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="@color/black"
                            android:alpha="0.4"/>

                        <EditText
                            android:id="@+id/etNama"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@null"
                            android:paddingStart="10dp"
                            android:hint="Masukkan nama lengkap"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BBBBBB"
                            android:inputType="textPersonName"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Label EMAIL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="EMAIL"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <!-- Field Email -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:cardCornerRadius="50dp"
                    app:cardBackgroundColor="#F2F2F2"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_dialog_email"
                            app:tint="@color/black"
                            android:alpha="0.4"/>

                        <EditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@null"
                            android:paddingStart="10dp"
                            android:hint="contoh@mail.com"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BBBBBB"
                            android:inputType="textEmailAddress"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Label PASSWORD -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="PASSWORD"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <!-- Field Password -->
                <!-- Field Password -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:cardCornerRadius="50dp"
                    app:cardBackgroundColor="#F2F2F2"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            app:tint="@color/black"
                            android:alpha="0.4"/>

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:paddingStart="10dp"
                            android:hint="Min. 8 karakter"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BBBBBB"
                            android:inputType="textPassword"/>

                        <!-- Toggle show/hide password -->
                        <ImageView
                            android:id="@+id/ivShowPassword"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_view"
                            app:tint="#AAAAAA"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Tombol Daftar -->
                <Button
                    android:id="@+id/btnDaftar"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:text="Daftar Sekarang"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_orange"
                    android:stateListAnimator="@null"/>

                <!-- Link Masuk -->
                <TextView
                    android:id="@+id/tvMasuk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Sudah punya akun? Masuk"
                    android:textSize="13sp"
                    android:textColor="#888888"/>

                <!-- Badge XP -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"
                    android:text="⭐ DAPATKAN +50 XP PERTAMA"
                    android:textSize="11sp"
                    android:textColor="#E8541A"
                    android:background="@drawable/bg_xp_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>