<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <View
            android:id="@+id/viewStrip"
            android:layout_width="4dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#FFF3EE"
            app:cardElevation="0dp">
            <TextView
                android:id="@+id/tvMisiIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textSize="18sp"
                android:gravity="center"/>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvMisiJudul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <TextView
                android:id="@+id/tvMisiLokasi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#888888"/>

            <TextView
                android:id="@+id/tvMisiPoin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#E8541A"
                android:textStyle="bold"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnSelesaikan"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Selesaikan"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            app:backgroundTint="@null"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>