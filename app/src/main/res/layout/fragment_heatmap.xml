<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Google Map -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Card Info di atas peta -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="50dp"
        android:layout_gravity="top"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <!-- Left: Score & Progress -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEDAN LIVE VITALS"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="2dp"/>

                <!-- City Impact Score row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="City Impact Score: "
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:id="@+id/tvImpactScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="85"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#E8541A"/>
                </LinearLayout>

                <!-- Daily Goal row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="DAILY GOAL"
                        android:textSize="10sp"
                        android:textColor="#AAAAAA"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tvReportCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12 LAPORAN"
                        android:textSize="10sp"
                        android:textColor="#AAAAAA"/>
                </LinearLayout>

                <!-- Progress Bar -->
                <ProgressBar
                    android:id="@+id/progressImpact"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="4dp"
                    android:progress="85"
                    android:progressTint="#E8541A"
                    android:progressBackgroundTint="#EEEEEE"/>
            </LinearLayout>

            <!-- Right: Badge +5% -->
            <TextView
                android:id="@+id/tvTrend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="↑ +5%"
                android:textSize="11sp"
                android:textColor="#1D9E75"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_green"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- FAB Filter/Legend (kanan bawah) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabFilter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_margin="16dp"
        android:layout_marginBottom="80dp"
        android:src="@android:drawable/ic_dialog_map"
        android:contentDescription="Lihat Legenda"
        app:backgroundTint="#E8541A"
        app:tint="@android:color/white"
        app:fabSize="normal"/>

</FrameLayout>