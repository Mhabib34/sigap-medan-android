<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Skeleton -->
    <include
        android:id="@+id/skeletonHadiah"
        layout="@layout/fragment_hadiah_skeleton"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:visibility="gone"
        android:visibility="visible"/>


    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshHadiah"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <!-- Content -->
        <ScrollView
            android:id="@+id/contentHadiah"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:visibility="visible"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="25dp">

                <!-- Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tukar Hadiahmu"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <!-- Card Saldo Poin -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/tertiary"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SALDO SAAT INI"
                                android:textSize="11sp"
                                android:textColor="#8B6914"/>

                            <TextView
                                android:id="@+id/tvSaldoPoin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Poinmu: 0 pts"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A1A"
                                android:lineSpacingExtra="2dp"/>

                        </LinearLayout>

                        <androidx.cardview.widget.CardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardCornerRadius="24dp"
                            app:cardBackgroundColor="#F5C400"
                            app:cardElevation="4dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="★"
                                android:textSize="24sp"
                                android:textColor="#FFFFFF"
                                android:gravity="center"/>
                        </androidx.cardview.widget.CardView>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Filter Tab -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tabSemuaHadiah"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="Semua"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:background="@drawable/bg_tab_misi_active"/>

                        <TextView
                            android:id="@+id/tabVoucher"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginStart="8dp"
                            android:text="Voucher"
                            android:textSize="13sp"
                            android:textColor="#888888"
                            android:gravity="center"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:background="@drawable/bg_tab_misi_inactive"/>

                        <TextView
                            android:id="@+id/tabBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginStart="8dp"
                            android:text="Badge"
                            android:textSize="13sp"
                            android:textColor="#888888"
                            android:gravity="center"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:background="@drawable/bg_tab_misi_inactive"/>

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Container Grid Hadiah (2 kolom) -->
                <LinearLayout
                    android:id="@+id/containerHadiah"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"/>

                <!-- Direkomendasikan -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Direkomendasikan Untukmu"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <LinearLayout
                    android:id="@+id/containerRekomendasi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="16dp"/>

            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</FrameLayout>