<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#E8541A"/>

            <TextView
                android:id="@+id/tvJudulLaporan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Laporkan Jalan Berlubang"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

        </LinearLayout>

        <!-- Progress step -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LANGKAH 1 DARI 2"
                android:textSize="11sp"
                android:textColor="#E8541A"
                android:textStyle="bold"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detail Laporan"
                android:textSize="11sp"
                android:textColor="#888888"/>

        </LinearLayout>

        <ProgressBar
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:progress="50"
            android:progressTint="#E8541A"
            android:progressBackgroundTint="#DDDDDD"/>

        <!-- Upload Foto -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFoto"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivFotoPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>

                <LinearLayout
                    android:id="@+id/layoutUpload"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <androidx.cardview.widget.CardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardBackgroundColor="#FFF3EE"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="#E8541A"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvFotoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Ambil Foto Jalan Berlubang"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:id="@+id/tvFotoSubLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Pastikan lubang terlihat jelas"
                        android:textSize="12sp"
                        android:textColor="#888888"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tombol kamera / galeri -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnKamera"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📷 Kamera"
                android:textSize="12sp"
                android:textColor="#E8541A"
                android:background="@drawable/bg_button_outline"
                android:stateListAnimator="@null"
                app:backgroundTint="@null"/>
        </LinearLayout>

        <!-- ===================== LOKASI KEJADIAN ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="#E8541A"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Lokasi Kejadian"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <!-- Status indikator GPS -->
            <TextView
                android:id="@+id/tvGpsStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔄 Mendeteksi..."
                android:textSize="10sp"
                android:textColor="#E8541A"/>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Baris atas: ikon peta + nama jalan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="#FFF3EE"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_mapmode"
                            app:tint="#E8541A"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <!-- Nama Jalan -->
                        <TextView
                            android:id="@+id/tvNamaJalan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mendapatkan nama jalan..."
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"/>

                        <!-- Kota/Kabupaten -->
                        <TextView
                            android:id="@+id/tvKota"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Kota Medan, Sumut"
                            android:textSize="12sp"
                            android:textColor="#888888"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="#F0F0F0"/>

                <!-- Grid detail lokasi: Kelurahan + Kecamatan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Kelurahan -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_location_chip"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍 Kelurahan"
                            android:textSize="10sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tvKelurahan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Mendeteksi..."
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                    </LinearLayout>

                    <!-- Kecamatan -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_location_chip"
                        android:padding="10dp"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏘️ Kecamatan"
                            android:textSize="10sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tvKecamatan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Mendeteksi..."
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Baris kedua: Kota + Kode Pos -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <!-- Kota/Kabupaten -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_location_chip"
                        android:padding="10dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏙️ Kota/Kabupaten"
                            android:textSize="10sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tvKotaChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Mendeteksi..."
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                    </LinearLayout>

                    <!-- Kode Pos -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_location_chip"
                        android:padding="10dp"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✉️ Kode Pos"
                            android:textSize="10sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tvKodePos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Mendeteksi..."
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="10dp"
                    android:background="#F0F0F0"/>

                <!-- Koordinat GPS (readonly) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_koordinat"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛰️ Koordinat GPS"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <!-- Latitude -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Latitude"
                                android:textSize="10sp"
                                android:textColor="#AAAAAA"/>

                            <TextView
                                android:id="@+id/tvLatitude"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="3.5952° N"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#E8541A"
                                android:fontFamily="monospace"/>

                        </LinearLayout>

                        <!-- Longitude -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Longitude"
                                android:textSize="10sp"
                                android:textColor="#AAAAAA"/>

                            <TextView
                                android:id="@+id/tvLongitude"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="98.6722° E"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#E8541A"
                                android:fontFamily="monospace"/>

                        </LinearLayout>

                        <!-- Akurasi -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Akurasi"
                                android:textSize="10sp"
                                android:textColor="#AAAAAA"/>

                            <TextView
                                android:id="@+id/tvAkurasi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="±5m"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#27AE60"
                                android:fontFamily="monospace"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Tombol refresh lokasi -->
                <Button
                    android:id="@+id/btnRefreshLokasi"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="10dp"
                    android:text="Perbarui Lokasi"
                    android:textSize="11sp"
                    android:textColor="#E8541A"
                    android:background="@drawable/bg_button_outline"
                    android:stateListAnimator="@null"
                    app:backgroundTint="@null"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!-- ===================== END LOKASI ===================== -->

        <!-- Catatan Tambahan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#E8541A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Catatan Tambahan"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#F5F5F5"
            app:cardElevation="0dp">

            <EditText
                android:id="@+id/etCatatan"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@null"
                android:padding="14dp"
                android:hint="Berikan detail singkat tentang kondisi jalan (kedalaman, luas, atau kendala lainnya)"
                android:textSize="13sp"
                android:textColor="#1A1A1A"
                android:textColorHint="#BBBBBB"
                android:inputType="textMultiLine"
                android:gravity="top"/>

        </androidx.cardview.widget.CardView>

        <!-- Tombol Kirim -->
        <Button
            android:id="@+id/btnKirimLaporan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:text="Kirim Laporan ➤"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_orange"
            android:stateListAnimator="@null"
            app:backgroundTint="@null"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:text="Laporanmu membantu mewujudkan Medan yang lebih baik."
            android:textSize="11sp"
            android:textColor="#888888"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>