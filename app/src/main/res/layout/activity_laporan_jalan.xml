<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#E8541A"/>

            <TextView
                android:id="@+id/tvJudulLaporan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Laporkan Jalan Berlubang"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

        </LinearLayout>

        <!-- Progress step -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LANGKAH 1 DARI 2"
                android:textSize="11sp"
                android:textColor="#E8541A"
                android:textStyle="bold"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detail Laporan"
                android:textSize="11sp"
                android:textColor="#888888"/>

        </LinearLayout>

        <ProgressBar
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:progress="50"
            android:progressTint="#E8541A"
            android:progressBackgroundTint="#DDDDDD"/>

        <!-- XP Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ +50 XP"
                android:textSize="12sp"
                android:textColor="#8B6914"
                android:textStyle="bold"
                android:background="@drawable/bg_xp_badge"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"/>
        </LinearLayout>

        <!-- Upload Foto -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFoto"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Preview foto (hidden by default) -->
                <ImageView
                    android:id="@+id/ivFotoPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>

                <!-- Placeholder upload -->
                <LinearLayout
                    android:id="@+id/layoutUpload"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <androidx.cardview.widget.CardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardBackgroundColor="#FFF3EE"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="#E8541A"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvFotoLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Ambil Foto Jalan Berlubang"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:id="@+id/tvFotoSubLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Pastikan lubang terlihat jelas"
                        android:textSize="12sp"
                        android:textColor="#888888"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tombol kamera / galeri -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnKamera"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📷 Kamera"
                android:textSize="12sp"
                android:textColor="#E8541A"
                android:background="@drawable/bg_button_outline"
                android:stateListAnimator="@null"
                app:backgroundTint="@null"/>

            <Button
                android:id="@+id/btnGaleri"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="🖼️ Galeri"
                android:textSize="12sp"
                android:textColor="#E8541A"
                android:background="@drawable/bg_button_outline"
                android:stateListAnimator="@null"
                app:backgroundTint="@null"/>

        </LinearLayout>

        <!-- Lokasi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_mylocation"
                android:tint="#E8541A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Lokasi Kejadian"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#F5F5F5"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="8dp"
                    app:cardBackgroundColor="#E8E8E8"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/ic_menu_mapmode"
                        android:scaleType="centerInside"
                        android:padding="8dp"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/tvAlamat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mendapatkan lokasi..."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>

                    <TextView
                        android:id="@+id/tvKota"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kota Medan, Sumut"
                        android:textSize="12sp"
                        android:textColor="#888888"/>

                </LinearLayout>

                <Button
                    android:id="@+id/btnGantiLokasi"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Ganti Lokasi"
                    android:textSize="11sp"
                    android:textColor="#E8541A"
                    android:background="@drawable/bg_button_outline"
                    android:stateListAnimator="@null"
                    app:backgroundTint="@null"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Catatan Tambahan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#E8541A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Catatan Tambahan"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#F5F5F5"
            app:cardElevation="0dp">

            <EditText
                android:id="@+id/etCatatan"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@null"
                android:padding="14dp"
                android:hint="Berikan detail singkat tentang kondisi jalan (kedalaman, luas, atau kendala lainnya)"
                android:textSize="13sp"
                android:textColor="#1A1A1A"
                android:textColorHint="#BBBBBB"
                android:inputType="textMultiLine"
                android:gravity="top"/>

        </androidx.cardview.widget.CardView>

        <!-- Tombol Kirim -->
        <Button
            android:id="@+id/btnKirimLaporan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:text="Kirim Laporan ➤"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_button_orange"
            android:stateListAnimator="@null"
            app:backgroundTint="@null"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:text="Laporanmu membantu mewujudkan Medan yang lebih baik."
            android:textSize="11sp"
            android:textColor="#888888"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>