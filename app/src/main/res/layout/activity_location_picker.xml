<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Map -->
    <fragment
        android:id="@+id/mapPickerFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- ✅ Pin tengah layar — selalu di center, tidak transparan -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:translationY="-24dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_mylocation"
            app:tint="#E8541A"/>

        <!-- Bayangan titik di bawah pin -->
        <View
            android:layout_width="10dp"
            android:layout_height="4dp"
            android:layout_marginTop="0dp"
            android:background="#44000000"
            android:translationY="-4dp"/>
    </LinearLayout>

    <!-- Header card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnBackPicker"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="#E8541A"
                    android:padding="2dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Pilih Lokasi di Peta"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>
            </LinearLayout>

            <!-- ✅ Instruksi geser peta -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="🗺️ Geser peta hingga pin tepat di lokasi kejadian"
                android:textSize="12sp"
                android:textColor="#888888"
                android:gravity="center"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom card: alamat + konfirmasi -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- ✅ Loading spinner saat geocoding -->
                <ProgressBar
                    android:id="@+id/pbAlamat"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Lokasi Dipilih"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:letterSpacing="0.08"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvAlamatPicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:text="Geser peta untuk memilih lokasi"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:minLines="1"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvKoordinat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text=""
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:fontFamily="monospace"/>

            <Button
                android:id="@+id/btnKonfirmasiLokasi"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="✓ Konfirmasi Lokasi Ini"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_button_orange"
                android:stateListAnimator="@null"
                android:enabled="false"
                app:backgroundTint="@null"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>