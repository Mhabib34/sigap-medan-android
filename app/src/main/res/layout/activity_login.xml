<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">


        <!-- Card Form -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="20dp">

                <!-- Icon bulat oranye (pindah ke sini) -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/logo_smartcity_oren"
                    android:scaleType="centerInside" />

                <!-- Judul (pindah ke sini) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SmartCity"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <!-- Subtitle (pindah ke sini) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp"
                    android:text="Platform Kota Cerdas Medan"
                    android:textSize="13sp"
                    android:textColor="#888888"/>

                <!-- Label EMAIL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:text="ALAMAT EMAIL"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <!-- Field Email -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:cardCornerRadius="50dp"
                    app:cardBackgroundColor="#F2F2F2"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_dialog_email"
                            app:tint="#AAAAAA"/>

                        <EditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@null"
                            android:paddingStart="10dp"
                            android:hint="nama@email.com"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BBBBBB"
                            android:inputType="textEmailAddress"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Label PASSWORD -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="KATA SANDI"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <!-- Field Password -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:cardCornerRadius="50dp"
                    app:cardBackgroundColor="#F2F2F2"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_lock_idle_lock"
                            app:tint="#AAAAAA"/>

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:paddingStart="10dp"
                            android:hint="••••••••"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BBBBBB"
                            android:inputType="textPassword"/>

                        <!-- Toggle show/hide password -->
                        <ImageView
                            android:id="@+id/ivShowPassword"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_view"
                            app:tint="#AAAAAA"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Tombol Masuk -->
                <Button
                    android:id="@+id/btnMasuk"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:text="@string/btn_masuk"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_orange"
                    android:stateListAnimator="@null" />

                <!-- Link ke Register -->
                <TextView
                    android:id="@+id/tvDaftar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:text="Belum punya akun? Daftar"
                    android:textSize="13sp"
                    android:textColor="#888888"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"
            android:text="@string/login_footer"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>