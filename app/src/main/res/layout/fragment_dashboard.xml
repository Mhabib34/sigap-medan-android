<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Skeleton -->
    <include
        android:id="@+id/skeletonDashboard"
        layout="@layout/fragment_dashboard_skeleton"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:visibility="gone"
        android:visibility="visible"/>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Content -->
        <ScrollView
            android:id="@+id/contentDashboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:visibility="visible"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="25dp"
                android:padding="16dp">

                <!-- Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Civic Vitality"
                    android:textSize="20sp"
                    android:layout_marginBottom="20dp"
                    android:textStyle="normal"
                    android:fontFamily="@font/poetsen_one_regular"
                    android:textColor="#000000"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ADMIN INSIGHTS"
                            android:textSize="10sp"
                            android:textColor="#E8541A"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dampak SmartCity\nMedan"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:fontFamily="@font/poetsen_one_regular"
                            android:lineSpacingExtra="2dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Stats Grid Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <!-- Total Laporan -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Laporan"
                                android:textSize="11sp"
                                android:textColor="#888888"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="1.284"
                                android:textSize="26sp"
                                android:fontFamily="@font/poetsen_one_regular"
                                android:textStyle="normal"
                                android:textColor="#E8541A"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Total Kontribusi -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Kontribusi"
                                android:textSize="11sp"
                                android:textColor="#888888"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="3.571"
                                android:textSize="26sp"
                                android:fontFamily="@font/poetsen_one_regular"
                                android:textStyle="normal"
                                android:textColor="#1A6B5A"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- Stats Grid Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <!-- Total User -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total User"
                                android:textSize="11sp"
                                android:textColor="#888888"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="892"
                                android:fontFamily="@font/poetsen_one_regular"
                                android:textSize="26sp"
                                android:textStyle="normal"
                                android:textColor="#1A1A1A"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Poin Beredar -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Poin Beredar"
                                android:textSize="11sp"
                                android:textColor="#888888"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="47.250"
                                android:textSize="26sp"
                                android:fontFamily="@font/poetsen_one_regular"
                                android:textStyle="normal"
                                android:textColor="#F5C400"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- Popular Missions Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Judul -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Popular Missions"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A1A1A"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Breakdown per category volume"
                                    android:textSize="11sp"
                                    android:textColor="#888888"/>

                            </LinearLayout>

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_sort_by_size"
                                app:tint="#888888"/>

                        </LinearLayout>

                        <!-- Bar Laporan Jalan 42% -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="16dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Laporan Jalan"
                                android:textSize="13sp"
                                android:fontFamily="@font/poetsen_one_regular"
                                android:textStyle="normal"
                                android:textColor="#1A1A1A"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="42%"
                                android:textSize="13sp"
                                android:textColor="#888888"/>
                        </LinearLayout>
                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="4dp"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progress="42"
                            android:progressTint="#E8541A"
                            android:progressBackgroundTint="#F0F0F0"/>

                        <!-- Bar Transportasi 28% -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="12dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Transportasi Publik"
                                android:textSize="13sp"
                                android:fontFamily="@font/poetsen_one_regular"
                                android:textStyle="normal"
                                android:textColor="#1A1A1A"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="28%"
                                android:textSize="13sp"
                                android:textColor="#888888"/>
                        </LinearLayout>
                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="4dp"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progress="28"
                            android:progressTint="#1A6B5A"
                            android:progressBackgroundTint="#F0F0F0"/>

                        <!-- Bar Kebersihan 18% -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="12dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Kebersihan Lingkungan"
                                android:textSize="13sp"
                                android:fontFamily="@font/poetsen_one_regular"
                                android:textStyle="normal"
                                android:textColor="#1A1A1A"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="18%"
                                android:textSize="13sp"
                                android:textColor="#888888"/>
                        </LinearLayout>
                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="4dp"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progress="18"
                            android:progressTint="#8B7A00"
                            android:progressBackgroundTint="#F0F0F0"/>

                        <!-- Bar Lain-lain 12% -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="12dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Lain-lain"
                                android:textSize="13sp"
                                android:fontFamily="@font/poetsen_one_regular"
                                android:textStyle="normal"
                                android:textColor="#1A1A1A"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12%"
                                android:textSize="13sp"
                                android:textColor="#888888"/>
                        </LinearLayout>
                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="4dp"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progress="12"
                            android:progressTint="#AAAAAA"
                            android:progressBackgroundTint="#F0F0F0"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Community Impact Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1A6B5A">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Icon + Label -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌿"
                                android:textSize="18sp"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="COMMUNITY"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:textColor="#AADDCC"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="IMPACT"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:textColor="#AADDCC"/>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Deskripsi -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Dalam 30 hari terakhir, inisiatif warga Medan telah mempercepat perbaikan infrastruktur sebesar 15% lebih awal dari target tahunan. Kolaborasi ini mengurangi waktu respon layanan publik dari 48 jam menjadi hanya 12 jam melalui pelaporan real-time."
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:lineSpacingExtra="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</FrameLayout>