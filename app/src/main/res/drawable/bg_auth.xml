<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background putih dasar -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F6F6F6"/>
        </shape>
    </item>

    <!-- Blob hijau/teal pojok kanan atas -->
    <item
        android:top="-200dp"
        android:right="-150dp"
        android:bottom="400dp"
        android:left="100dp">
        <shape android:shape="oval">
            <solid android:color="#807CF6EC"/>
        </shape>
    </item>

    <!-- Blob oranye pojok kiri bawah -->
    <item
        android:top="400dp"
        android:right="100dp"
        android:bottom="-200dp"
        android:left="-150dp">
        <shape android:shape="oval">
            <solid android:color="#80FF7949"/>
        </shape>
    </item>

</layer-list>